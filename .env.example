# Copier ce fichier en ".env" et remplir avec tes vraies valeurs
# Ne jamais committer le fichier ".env" (déjà exclu via .gitignore)

# --- Supabase (Project Settings > API) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=colle_ici_ta_clé_service_role

# --- Port (Render le définit automatiquement, inutile de le changer) ---
PORT=3000
